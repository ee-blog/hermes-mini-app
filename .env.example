# ── Hermes Mini App v2 ──
# Rename to .env and fill in your values

# Required: API Token (frontend sends this in X-API-Token header)
MINI_APP_TOKEN=hermes-mini-app-2024

# Optional: Maintenance password (for operations tab)
OPS_PASSWORD=your-ops-password

# Optional: IP whitelist for maintenance (comma-separated)
OPS_WHITELIST=127.0.0.1,::1

# Network interface for vnstat (monthly traffic)
NET_IFACE=enp0s6

# Monthly quota in bytes (default: 10 TB)
MONTHLY_QUOTA=10995116277760

# Ollama config
OLLAMA_URL=http://127.0.0.1:11434
CHAT_MODEL=gemma4:e2b

# Server bind
SERVER_HOST=127.0.0.1
SERVER_PORT=9120
