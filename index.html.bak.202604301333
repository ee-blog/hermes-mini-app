<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>奕奕Blog丨Hermes Control</title>
    <link rel="icon" href="https://www.eebk.com/favicon.ico">
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <style>
        :root {
            --bg: var(--tg-theme-bg-color, #0f0f1a);
            --bg2: var(--tg-theme-secondary-bg-color, #1a1a2e);
            --text: var(--tg-theme-text-color, #e0e0e0);
            --hint: var(--tg-theme-hint-color, #6b7280);
            --accent: var(--tg-theme-button-color, #5288c1);
            --accent-text: var(--tg-theme-button-text-color, #fff);
            --link: var(--tg-theme-link-color, #64b5f6);
            --danger: #ef4444;
            --success: #22c55e;
            --warn: #f59e0b;
            --radius: 12px;
        }
        * { margin:0; padding:0; box-sizing:border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
        }

        .tab-nav {
            display: flex;
            background: var(--bg2);
            position: sticky; top: 0; z-index: 100;
            border-bottom: 1px solid rgba(255,255,255,0.06);
        }
        .tab-btn {
            flex: 1;
            padding: 14px 8px;
            border: none;
            background: none;
            color: var(--hint);
            font-size: 12px;
            font-weight: 500;
            cursor: pointer;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            transition: color 0.2s;
        }
        .tab-btn.active { color: var(--accent); }
        .tab-btn .tab-icon { font-size: 18px; }

        .page { display: none; padding: 14px; max-width: 440px; margin: 0 auto; }
        .page.active { display: block; }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: rgba(34,197,94,0.15);
            color: var(--success);
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 500;
        }
        .status-dot {
            width: 8px; height: 8px;
            background: var(--success);
            border-radius: 50%;
            animation: pulse 2s infinite;
        }
        @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }

        .section-title {
            font-size: 12px;
            color: var(--hint);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin: 18px 0 10px;
        }

        .card {
            background: var(--bg2);
            border-radius: var(--radius);
            padding: 14px;
            margin-bottom: 10px;
        }

        .gauge-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-bottom: 10px;
        }
        .gauge-card {
            background: var(--bg2);
            border-radius: var(--radius);
            padding: 14px;
        }
        .gauge-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
        }
        .gauge-label { font-size: 12px; color: var(--hint, #8e9297); font-weight: 500; letter-spacing: 0.5px; }
        .gauge-value { font-size: 20px; font-weight: 700; color: var(--text, #ffffff); }
        .gauge-bar {
            height: 5px;
            background: rgba(255,255,255,0.08);
            border-radius: 3px;
            overflow: hidden;
            margin-top: 6px;
        }
        .gauge-fill {
            height: 100%;
            border-radius: 3px;
            transition: width 0.5s ease;
        }
        .fill-green { background: linear-gradient(90deg, #22c55e, #4ade80); }
        .fill-yellow { background: linear-gradient(90deg, #f59e0b, #fbbf24); }
        .fill-red { background: linear-gradient(90deg, #ef4444, #f87171); }
        .fill-blue { background: linear-gradient(90deg, #3b82f6, #60a5fa); }

        .info-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 6px 0;
            font-size: 13px;
        }
        .info-row + .info-row { border-top: 1px solid rgba(255,255,255,0.05); }

        .proc-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 7px 0;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            font-size: 12px;
        }
        .proc-name {
            flex: 1;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            margin: 0 8px;
        }
        .proc-cpu { color: var(--success); min-width: 38px; text-align: right; }
        .proc-mem { color: var(--link); min-width: 48px; text-align: right; }

        .model-card {
            background: var(--bg2);
            border-radius: var(--radius);
            padding: 14px;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .model-icon { font-size: 28px; }
        .model-info { flex: 1; }
        .model-name { font-weight: 600; font-size: 15px; }
        .model-provider { font-size: 11px; color: var(--hint); margin-top: 2px; }

        .platform-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 8px;
        }
        .platform-item {
            background: rgba(255,255,255,0.03);
            border-radius: 10px;
            padding: 10px 6px;
            text-align: center;
        }
        .platform-icon { width:22px; height:22px; margin:0 auto 4px; display:flex; align-items:center; justify-content:center; }
        .platform-name { font-size: 11px; color: var(--hint); }
        .platform-status { font-weight: 600; font-size: 12px; margin-top: 3px; }
        .platform-status.online { color: var(--success); }
        .platform-status.offline { color: var(--danger); }

        .stats-row {
            display: flex;
            gap: 8px;
        }
        .stat-box {
            flex: 1;
            background: rgba(255,255,255,0.03);
            border-radius: 8px;
            padding: 10px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }
        .stat-num { font-size: 22px; font-weight: 700; color: var(--accent); }
        .stat-label { font-size: 10px; color: var(--hint); margin-top: 2px; }

        /* Memory Stats Grid */
        .memory-stats-grid {
            display: grid;
            grid-template-columns: 1fr 40px 1.2fr;
            gap: 0;
            position: relative;
        }
        .memory-left {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .memory-row {
            background: rgba(255,255,255,0.03);
            border-radius: 12px;
            padding: 14px 12px;
            display: flex;
            align-items: center;
            gap: 10px;
            position: relative;
            overflow: hidden;
        }
        #stat-writes-box {
            background: linear-gradient(135deg, rgba(249,115,22,0.12), rgba(249,115,22,0.03));
        }
        #stat-queries-box {
            background: linear-gradient(135deg, rgba(59,130,246,0.12), rgba(59,130,246,0.03));
        }
        .memory-info { flex: 1; text-align: center; }
        .memory-info .stat-num { font-size: 22px; }
        .memory-info .stat-label { font-size: 10px; }

        /* Flow Bridge - 中间数据流通道 */
        .flow-bridge {
            display: flex;
            flex-direction: column;
            justify-content: space-around;
            padding: 4px 0;
            position: relative;
        }
        .bridge-row {
            height: 40px;
            position: relative;
            display: flex;
            align-items: center;
        }
        .bridge-dot {
            position: absolute;
            font-size: 8px;
            opacity: 0;
        }

        /* 写入：从左向右飞向大脑 */
        .write-bridge .bridge-dot {
            color: #f97316;
            animation: flyRight 1.8s ease-in-out infinite;
        }
        .write-bridge .wd1 { animation-delay: 0s; }
        .write-bridge .wd2 { animation-delay: 0.6s; }
        .write-bridge .wd3 { animation-delay: 1.2s; }

        @keyframes flyRight {
            0% { left: 0; opacity: 0.9; transform: scale(1); }
            70% { opacity: 0.7; }
            100% { left: calc(100% - 8px); opacity: 0; transform: scale(0.5); }
        }

        /* 查询：从右向左飞出大脑 */
        .query-bridge .bridge-dot {
            color: #3b82f6;
            animation: flyLeft 1.8s ease-in-out infinite;
        }
        .query-bridge .qd1 { animation-delay: 0s; }
        .query-bridge .qd2 { animation-delay: 0.6s; }
        .query-bridge .qd3 { animation-delay: 1.2s; }

        @keyframes flyLeft {
            0% { right: 0; left: auto; opacity: 0.9; transform: scale(1); }
            70% { opacity: 0.7; }
            100% { right: calc(100% - 8px); left: auto; opacity: 0; transform: scale(0.5); }
        }

        /* Idle states */
        .flow-bridge.idle .bridge-dot {
            animation-play-state: paused;
            opacity: 0.15;
        }
        .write-bridge.idle .bridge-dot { left: 50%; right: auto; }
        .query-bridge.idle .bridge-dot { right: 50%; left: auto; }

        /* Brain Card */
        .memory-brain {
            background: linear-gradient(135deg, rgba(139,92,246,0.1), rgba(59,130,246,0.05));
            border-radius: 12px;
            padding: 16px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
            grid-row: span 2;
        }
        .brain-icon {
            font-size: 36px;
            animation: brainFloat 3s ease-in-out infinite;
            position: relative;
            z-index: 2;
        }
        @keyframes brainFloat {
            0%, 100% { transform: translateY(0) scale(1); }
            50% { transform: translateY(-4px) scale(1.05); }
        }
        .brain-count {
            font-size: 28px;
            font-weight: 700;
            color: var(--accent);
            margin: 6px 0 2px;
            position: relative;
            z-index: 2;
        }
        .brain-label {
            font-size: 11px;
            color: var(--hint);
            position: relative;
            z-index: 2;
        }

        /* Pulse */
        .brain-pulse {
            position: absolute;
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(139,92,246,0.3), transparent 70%);
            animation: brainPulse 2s ease-in-out infinite;
        }
        @keyframes brainPulse {
            0%, 100% { transform: scale(0.8); opacity: 0.6; }
            50% { transform: scale(1.2); opacity: 0.3; }
        }

        /* Neurons */
        .neurons {
            position: absolute;
            inset: 0;
            pointer-events: none;
        }
        .neuron {
            position: absolute;
            font-size: 6px;
            color: rgba(139,92,246,0.6);
            animation: neuronBlink 2s ease-in-out infinite;
        }
        .neuron.n1 { top: 15%; left: 20%; animation-delay: 0s; }
        .neuron.n2 { top: 25%; right: 15%; animation-delay: 0.4s; }
        .neuron.n3 { bottom: 30%; left: 25%; animation-delay: 0.8s; }
        .neuron.n4 { top: 60%; right: 20%; animation-delay: 1.2s; }
        .neuron.n5 { bottom: 15%; right: 35%; animation-delay: 1.6s; }
        @keyframes neuronBlink {
            0%, 100% { opacity: 0.2; text-shadow: none; }
            50% { opacity: 1; text-shadow: 0 0 8px rgba(139,92,246,0.8); }
        }

        /* Idle state */
        .memory-brain.idle .brain-icon { animation: none; }
        .memory-brain.idle .brain-pulse { animation: none; opacity: 0.2; }
        .memory-brain.idle .neuron { animation: none; opacity: 0.15; }

        /* Uptime Bar - 底部状态条 */
        .uptime-bar {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 12px 16px;
            margin-top: 12px;
            background: linear-gradient(90deg, rgba(34,197,94,0.08), rgba(34,197,94,0.15), rgba(34,197,94,0.08));
            border-radius: 12px;
            position: relative;
            overflow: hidden;
        }
        .uptime-heartbeat {
            color: #22c55e;
            font-size: 14px;
            animation: heartbeat 1.2s ease-in-out infinite;
        }
        @keyframes heartbeat {
            0%, 100% { transform: scale(1); opacity: 0.8; }
            50% { transform: scale(1.2); opacity: 1; }
        }
        .uptime-text {
            font-size: 13px;
            font-weight: 600;
            color: var(--text);
        }
        .uptime-label {
            font-size: 11px;
            color: var(--hint);
        }
        .uptime-line {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, #22c55e, transparent);
            animation: linePulse 2s ease-in-out infinite;
        }
        @keyframes linePulse {
            0%, 100% { opacity: 0.3; }
            50% { opacity: 0.8; }
        }

        .traffic-row {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }
        .traffic-row:last-child { border-bottom: none; }
        .traffic-label { font-size: 13px; color: var(--hint, #8e9297); }
        .traffic-value { font-size: 13px; font-weight: 500; color: var(--text, #fff); }

        .cron-job-row {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 7px 0;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            font-size: 13px;
        }
        .cron-job-row:last-child { border-bottom: none; }
        .cron-name { flex: 1; color: var(--text, #fff); font-weight: 500; }
        .cron-status { font-weight: 600; white-space: nowrap; }
        .cron-next { font-size: 11px; color: var(--hint, #8e9297); white-space: nowrap; }
        .traffic-value.up { color: var(--success); }
        .traffic-value.down { color: var(--link); }

        .ops-btn {
            padding: 8px 6px;
            border: none;
            border-radius: var(--radius);
            font-size: 12px;
            font-weight: 500;
            cursor: pointer;
            transition: opacity 0.2s;
        }
        .ops-btn:active { opacity: 0.7; }
        .ops-btn.primary {
            background: var(--accent);
            color: var(--accent-text);
        }
        .ops-btn.danger {
            background: rgba(239,68,68,0.15);
            color: var(--danger);
        }
        .ops-btn.success {
            background: rgba(34,197,94,0.15);
            color: var(--success);
        }


    
    /* === PC Responsive === */
    @media (min-width: 768px) {
        body { background: #08080f; }
        .tab-nav { max-width: 900px; margin: 12px auto 0; border-radius: 12px 12px 0 0; }
        .tab-btn { padding: 14px 20px; font-size: 13px; }
        .tab-btn .tab-icon { font-size: 20px; }
        .page { max-width: 900px; padding: 20px 24px; margin: 0 auto; }
        #page-monitor.active { display: grid; grid-template-columns: 1fr 1fr; gap: 8px 16px; }
        #page-monitor.active > div:first-child { grid-column: 1 / -1; }
        .gauge-grid { grid-column: 1 / -1; grid-template-columns: repeat(4, 1fr); gap: 12px; }
        #page-monitor.active .uptime-bar { grid-column: 1 / -1; }
        #page-monitor.active .bottom-cards-grid { grid-column: 1 / -1; }
        .gauge-card { padding: 14px; }
        .gauge-value { font-size: 20px; }
        .card { padding: 14px; }
        .section-title { font-size: 12px; margin: 0 0 8px; font-weight: 600; color: #9ca3af; }
        #page-hermes.active { display: block; max-width: 900px; }
        .model-card { width: 100%; }
        .platform-grid { grid-template-columns: repeat(3, 1fr); gap: 10px; }
        .memory-stats-grid { max-width: 100%; }
        #page-ops.active { display: block; max-width: 900px; }
        .ops-btn { padding: 10px 12px; font-size: 12px; }
    }
    /* 聊天样式 - 全端通用 */
    .chat-container { display: flex; flex-direction: column; }
    .chat-messages { height: 380px; overflow-y: auto; padding: 10px; background: var(--bg2); }
    .chat-messages::-webkit-scrollbar { width: 4px; }
    .chat-messages::-webkit-scrollbar-track { background: transparent; }
    .chat-messages::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px; }
    .chat-messages::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.2); }
    .chat-messages { scrollbar-width: thin; scrollbar-color: rgba(255,255,255,0.1) transparent; }
    .chat-msg { margin-bottom: 8px; padding: 8px 12px; border-radius: 10px; max-width: 85%; word-wrap: break-word; font-size: 13px; }
    .chat-msg.user { background: var(--accent); color: #fff; margin-left: auto; }
    .chat-msg.assistant { background: var(--card); border: 1px solid var(--border); }
    .chat-msg.assistant code { background: rgba(0,0,0,0.3); padding: 2px 5px; border-radius: 4px; font-size: 12px; }
    .chat-msg.assistant pre { background: rgba(0,0,0,0.4); padding: 8px; border-radius: 6px; overflow-x: auto; margin: 8px 0; }
    .chat-msg.assistant pre code { background: none; padding: 0; }
    .chat-msg.assistant ul, .chat-msg.assistant ol { margin: 6px 0; padding-left: 20px; }
    .chat-msg.assistant li { margin: 2px 0; }
    .chat-msg.assistant p { margin: 6px 0; }
    .chat-msg.assistant strong { color: var(--accent); }
    .chat-msg.error { background: rgba(239,68,68,0.1); border: 1px solid var(--danger); color: var(--danger); }
    .chat-input-wrap { display: flex; gap: 8px; padding: 8px; background: var(--card); border-top: 1px solid var(--border); }
    .chat-input { flex: 1; padding: 10px 12px; border-radius: 8px; border: 1px solid var(--border); background: var(--bg2); color: var(--text); font-size: 13px; }
    .chat-input:focus { outline: none; border-color: var(--accent); }
    .chat-send { padding: 10px 16px; background: var(--accent); color: #fff; border: none; border-radius: 8px; cursor: pointer; font-weight: 600; font-size: 13px; }
    .chat-send:hover { opacity: 0.9; }
    .chat-send:disabled { opacity: 0.5; cursor: not-allowed; }
    .chat-typing { color: var(--hint); font-size: 12px; }
    .app-header { display: none; }
    @media (min-width: 768px) {
        .app-header { display: block; max-width: 900px; margin: 0 auto; padding: 16px 0 8px; }
        .app-header h1 { font-size: 18px; font-weight: 600; text-align: center; margin-bottom: 4px; }
        .app-header p { font-size: 11px; color: #6b7280; text-align: center; }
    }
    /* 骨架屏样式 */
    .skeleton {
        background: linear-gradient(90deg, var(--bg2) 25%, rgba(255,255,255,0.08) 50%, var(--bg2) 75%);
        background-size: 200% 100%;
        animation: shimmer 1.5s infinite;
        border-radius: 6px;
        min-height: 1em;
        min-width: 3em;
    }
    @keyframes shimmer {
        0% { background-position: 200% 0; }
        100% { background-position: -200% 0; }
    }
    .skeleton-text { height: 14px; margin: 6px 0; }
    .skeleton-text.sm { width: 60%; }
    .skeleton-text.lg { width: 80%; }
    .skeleton-row { display: flex; justify-content: space-between; padding: 8px 0; }
    .skeleton-row .skeleton { flex: 1; margin: 0 4px; }
    /* 底部卡片两列布局 */
    .bottom-cards-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-bottom: 10px;
    }
    .bottom-cards-grid .card {
        margin-bottom: 0;
        height: 140px;
        overflow: hidden;
        position: relative;
    }
    .bottom-cards-grid .card.span-2 {
        grid-column: span 2;
        height: auto;
        min-height: 140px;
        max-height: 320px;
        overflow-y: auto;
    }
    /* 紧凑内部间距 */
    .bottom-cards-grid .section-title { margin-bottom: 6px; }
    .bottom-cards-grid .traffic-row { padding: 5px 0; }
    .bottom-cards-grid .info-row { padding: 5px 0; }
    .bottom-cards-grid .proc-item { padding: 5px 0; }
    /* 进程名渐变消失 */
    .bottom-cards-grid .proc-name {
        flex: 1;
        max-width: 90px;
        overflow: hidden;
        white-space: nowrap;
        text-overflow: ellipsis;
    }
    .bottom-cards-grid .proc-cpu { min-width: 40px; text-align: right; }
    .bottom-cards-grid .proc-mem { min-width: 44px; text-align: right; }
    /* 网络流量紧凑 */
    .bottom-cards-grid .traffic-value { font-size: 12px; }
    </style>

</head>
<body>
    <div class="app-header">
        <h1>Hermes Control Panel</h1>
        <p>tg.eebk.com · System Monitor</p>
    </div>
    <div class="tab-nav">
        <button class="tab-btn active" onclick="switchTab('monitor')">
            <span class="tab-icon">📊</span>监控
        </button>
        <button class="tab-btn" onclick="switchTab('hermes')">
            <span class="tab-icon">🤖</span>Hermes
        </button>
        <button class="tab-btn" onclick="switchTab('ops')">
            <span class="tab-icon">🔧</span>维护
        </button>

    </div>

    <!-- === Monitor Page === -->
    <div id="page-monitor" class="page active">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
            <span class="status-badge"><span class="status-dot"></span>在线</span>
            <span style="font-size:11px;color:var(--hint)" id="current-time">--</span>
        </div>

        <div class="gauge-grid">
            <div class="gauge-card">
                <div class="gauge-header">
                    <span class="gauge-label">CPU</span>
                    <span class="gauge-value" id="cpu-val">--</span>
                </div>
                <div class="gauge-bar"><div class="gauge-fill fill-green" id="cpu-bar" style="width:0%"></div></div>
                <div style="font-size:10px;color:var(--hint);margin-top:6px;white-space:nowrap" id="cpu-detail">--</div>
            </div>
            <div class="gauge-card">
                <div class="gauge-header">
                    <span class="gauge-label">内存</span>
                    <span class="gauge-value" id="mem-val">--</span>
                </div>
                <div class="gauge-bar"><div class="gauge-fill fill-blue" id="mem-bar" style="width:0%"></div></div>
                <div style="font-size:11px;color:var(--hint);margin-top:6px" id="mem-detail">--</div>
            </div>
            <div class="gauge-card">
                <div class="gauge-header">
                    <span class="gauge-label">磁盘</span>
                    <span class="gauge-value" id="disk-val">--</span>
                </div>
                <div class="gauge-bar"><div class="gauge-fill fill-yellow" id="disk-bar" style="width:0%"></div></div>
                <div style="font-size:11px;color:var(--hint);margin-top:6px" id="disk-detail">--</div>
            </div>
            <div class="gauge-card">
                <div class="gauge-header">
                    <span class="gauge-label">负载</span>
                    <span class="gauge-value" id="load-val">--</span>
                </div>
                <div style="font-size:11px;color:var(--hint);margin-top:6px" id="load-detail">--</div>
            </div>
        </div>

        <div class="bottom-cards-grid">
        <div class="card" id="traffic-card">
            <div class="section-title">网络流量</div>
            <div class="traffic-row">
                <span class="traffic-label">↑ 上传</span>
                <span class="traffic-value up" id="net-up">--</span>
            </div>
            <div class="traffic-row">
                <span class="traffic-label">↓ 下载</span>
                <span class="traffic-value down" id="net-down">--</span>
            </div>
            <div class="traffic-row">
                <span class="traffic-label">月额度</span>
                <span class="traffic-value" id="net-quota">--</span>
            </div>
        </div>

        <div class="card" id="oci-billing-card">
            <div class="section-title">☁️ OCI 账单</div>
            <div class="skeleton skeleton-text lg"></div>
            <div class="skeleton skeleton-text sm"></div>
        </div>

        <div class="card" id="cpu-top">
            <div class="section-title">CPU TOP</div>
            <div class="skeleton-row"><div class="skeleton skeleton-text"></div><div class="skeleton skeleton-text sm"></div></div>
            <div class="skeleton-row"><div class="skeleton skeleton-text"></div><div class="skeleton skeleton-text sm"></div></div>
            <div class="skeleton-row"><div class="skeleton skeleton-text"></div><div class="skeleton skeleton-text sm"></div></div>
        </div>

        <div class="card" id="mem-top">
            <div class="section-title">内存 TOP</div>
            <div class="skeleton-row"><div class="skeleton skeleton-text"></div><div class="skeleton skeleton-text sm"></div></div>
            <div class="skeleton-row"><div class="skeleton skeleton-text"></div><div class="skeleton skeleton-text sm"></div></div>
            <div class="skeleton-row"><div class="skeleton skeleton-text"></div><div class="skeleton skeleton-text sm"></div></div>
        </div>

        <div class="card span-2" id="cron-card">
            <div class="section-title">⏰ 定时任务</div>
            <div class="skeleton skeleton-text lg"></div>
            <div class="skeleton skeleton-text sm"></div>
        </div>

        </div>

        <div class="uptime-bar">
            <span class="uptime-heartbeat">♥</span>
            <span class="uptime-text" id="stat-uptime-monitor">--</span>
            <span class="uptime-label">运行中</span>
            <div class="uptime-line"></div>
        </div>
    </div>

    <!-- === Hermes Page === -->
    <div id="page-hermes" class="page">
        <div class="model-card">
            <span class="model-icon">🧠</span>
            <div class="model-info">
                <div class="model-name" id="model-name">--</div>
                <div class="model-provider" id="model-provider">--</div>
            </div>
        </div>

        <div class="card">
            <div style="font-size:14px;font-weight:600;margin-bottom:10px">⚙️ 驱动引擎</div>
            <div id="engine-list">
                <div class="info-row"><span>🤖 LLM</span><span style="color:var(--hint)">--</span></div>
                <div class="info-row"><span>💾 记忆</span><span style="color:var(--hint)">--</span></div>
                <div class="info-row"><span>🧮 向量引擎</span><span style="color:var(--hint)">--</span></div>
                <div class="info-row"><span>🔎 向量库</span><span style="color:var(--hint)">--</span></div>
            </div>
        </div>

        <div class="card">
            <div style="font-size:14px;font-weight:600;margin-bottom:10px">🔗 平台连接</div>
            <div class="platform-grid" id="platform-grid">
                <div class="platform-item"><div class="platform-icon"><svg viewBox="0 0 24 24" width="22" height="22" fill="#26A5E4"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg></div><div class="platform-name">Telegram</div><div class="platform-status">--</div></div>
                <div class="platform-item"><div class="platform-icon"><svg viewBox="0 0 24 24" width="22" height="22" fill="#12B7F5"><path d="M21.395 15.035a40 40 0 0 0-.803-2.264l-1.079-2.695c.001-.032.014-.562.014-.836C19.526 4.632 17.351 0 12 0S4.474 4.632 4.474 9.241c0 .274.013.804.014.836l-1.08 2.695a39 39 0 0 0-.802 2.264c-1.021 3.283-.69 4.643-.438 4.673.54.065 2.103-2.472 2.103-2.472 0 1.469.756 3.387 2.394 4.771-.612.188-1.363.479-1.845.835-.434.32-.379.646-.301.778.343.578 5.883.369 7.482.189 1.6.18 7.14.389 7.483-.189.078-.132.132-.458-.301-.778-.483-.356-1.233-.646-1.846-.836 1.637-1.384 2.393-3.302 2.393-4.771 0 0 1.563 2.537 2.103 2.472.251-.03.581-1.39-.438-4.673"/></svg></div><div class="platform-name">QQ</div><div class="platform-status">--</div></div>
                <div class="platform-item"><div class="platform-icon"><svg viewBox="0 0 24 24" width="22" height="22" fill="#07C160"><path d="M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 0 1 .213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.29.295a.326.326 0 0 0 .167-.054l1.903-1.114a.864.864 0 0 1 .717-.098 10.16 10.16 0 0 0 2.837.403c.276 0 .543-.027.811-.05-.857-2.578.157-4.972 1.932-6.446 1.703-1.415 3.882-1.98 5.853-1.838-.576-3.583-4.196-6.348-8.596-6.348zM5.785 5.991c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 0 1-1.162 1.178A1.17 1.17 0 0 1 4.623 7.17c0-.651.52-1.18 1.162-1.18zm5.813 0c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 0 1-1.162 1.178 1.17 1.17 0 0 1-1.162-1.178c0-.651.52-1.18 1.162-1.18zm5.34 2.867c-1.797-.052-3.746.512-5.28 1.786-1.72 1.428-2.687 3.72-1.78 6.22.942 2.453 3.666 4.229 6.884 4.229.826 0 1.622-.12 2.361-.336a.722.722 0 0 1 .598.082l1.584.926a.272.272 0 0 0 .14.047c.134 0 .24-.111.24-.247 0-.06-.023-.12-.038-.177l-.327-1.233a.582.582 0 0 1-.023-.156.49.49 0 0 1 .201-.398C23.024 18.48 24 16.82 24 14.98c0-3.21-2.931-5.837-6.656-6.088V8.89c-.135-.01-.27-.027-.407-.03zm-2.53 3.274c.535 0 .969.44.969.982a.976.976 0 0 1-.969.983.976.976 0 0 1-.969-.983c0-.542.434-.982.97-.982zm4.844 0c.535 0 .969.44.969.982a.976.976 0 0 1-.969.983.976.976 0 0 1-.969-.983c0-.542.434-.982.969-.982z"/></svg></div><div class="platform-name">微信</div><div class="platform-status">--</div></div>
            </div>
        </div>

        <div class="section-title">🧠 记忆引擎</div>
        <div class="memory-stats-grid" id="memory-stats-grid">
            <!-- 左侧：写入 + 查询 -->
            <div class="memory-left">
                <div class="memory-row" id="stat-writes-box">
                    <div class="memory-info">
                        <div class="stat-num" id="stat-mem-writes">--</div>
                        <div class="stat-label">今日写入</div>
                    </div>
                </div>
                <div class="memory-row" id="stat-queries-box">
                    <div class="memory-info">
                        <div class="stat-num" id="stat-mem-queries">--</div>
                        <div class="stat-label">今日查询</div>
                    </div>
                </div>
            </div>
            <!-- 中间：数据流箭头 -->
            <div class="flow-bridge">
                <!-- 写入：左→右，飞向大脑 -->
                <div class="bridge-row write-bridge" id="write-bridge">
                    <span class="bridge-dot wd1">●</span>
                    <span class="bridge-dot wd2">●</span>
                    <span class="bridge-dot wd3">●</span>
                </div>
                <!-- 查询：右→左，从大脑飞出 -->
                <div class="bridge-row query-bridge" id="query-bridge">
                    <span class="bridge-dot qd1">●</span>
                    <span class="bridge-dot qd2">●</span>
                    <span class="bridge-dot qd3">●</span>
                </div>
            </div>
            <!-- 右侧：记忆总量 -->
            <div class="memory-brain" id="stat-brain">
                <div class="brain-icon">🧠</div>
                <div class="brain-count" id="stat-memory">--</div>
                <div class="brain-label">记忆总量</div>
                <div class="brain-pulse"></div>
                <div class="neurons">
                    <span class="neuron n1">●</span>
                    <span class="neuron n2">●</span>
                    <span class="neuron n3">●</span>
                    <span class="neuron n4">●</span>
                    <span class="neuron n5">●</span>
                </div>
            </div>
        </div>

        <!-- 运行时间 - 底部状态条 -->
        <div class="uptime-bar">
            <span class="uptime-heartbeat">♥</span>
            <span class="uptime-text" id="stat-uptime-hermes">--</span>
            <span class="uptime-label">运行中</span>
            <div class="uptime-line"></div>
        </div>
    </div>

    <!-- === Maintenance Page === -->
    <div id="page-ops" class="page">
        <!-- 密码验证界面 -->
        <div id="ops-login" class="card" style="display:none;text-align:center;padding:24px">
            <div style="font-size:14px;font-weight:600;margin-bottom:16px">🔒 访问验证</div>
            <div style="font-size:12px;color:var(--hint);margin-bottom:16px" id="ops-ip-msg">检测中...</div>
            <input type="password" id="ops-password-input" placeholder="输入密码" class="form-input"
                   style="width:100%;margin-bottom:12px;padding:10px;border-radius:8px;border:1px solid rgba(255,255,255,0.1);background:rgba(255,255,255,0.05);color:var(--text);text-align:center"
                   onkeydown="if(event.key==='Enter')submitOpsPassword()">
            <button class="ops-btn primary" style="width:100%" onclick="submitOpsPassword()">验证</button>
        </div>

        <!-- 操作界面 -->
        <div id="ops-panel" style="display:none">
            <div style="font-size:12px;font-weight:600;margin-bottom:6px;color:var(--hint)">💬 AI 助手 <span style="font-weight:400">(自动识别网址)</span></div>
            <div class="card" style="padding:0;overflow:hidden">
                <div class="chat-messages" id="chat-messages">
                    <div class="chat-msg assistant">👋 你好！我是 Qwen，有什么可以帮你的？（发送网址会自动抓取分析）</div>
                </div>
                <div class="chat-input-wrap">
                    <input type="text" class="chat-input" id="chat-input" placeholder="输入消息或网址..." autocomplete="off">
                    <button class="chat-send" id="chat-send" onclick="sendChat()">发送</button>
                </div>
            </div>

            <div style="font-size:12px;font-weight:600;margin-bottom:6px;color:var(--hint)">📋 操作日志</div>
            <div class="card" id="ops-log" style="min-height:50px;margin-bottom:10px">
                <div style="color:var(--hint);font-size:12px">点击下方按钮执行操作</div>
            </div>

            <div style="display:flex;gap:8px;margin-bottom:10px">
                <button class="ops-btn danger" style="flex:1" onclick="emergencyRestart()">
                    🚨 紧急重启
                </button>
                <button class="ops-btn primary" style="flex:1" onclick="restartService('gateway')">
                    🔄 重启 Gateway
                </button>
            </div>
        </div>

        <div class="uptime-bar">
            <span class="uptime-heartbeat">♥</span>
            <span class="uptime-text" id="stat-uptime-ops">--</span>
            <span class="uptime-label">运行中</span>
            <div class="uptime-line"></div>
        </div>
    </div>

    <script src="/mini-app/static/app.js"></script>
    <script>
        const API = '/api';
        const TOKEN='hermes...2024';
        const tg = window.Telegram?.WebApp;
        if (tg) { tg.expand(); tg.setHeaderColor('#1a1a2e'); }
        if (tg?.ReadyButton) { tg.ready(); }
        
        // esc - escape HTML entities
        function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
        
        function refreshSystemInfo() {
            fetch(API+'/hermes/summary').then(r=>r.json()).then(d=>{
                if (!d.model) return;
                document.getElementById('model-name').textContent = d.model || 'Unknown';
                document.getElementById('uptime').textContent = d.uptime || 'N/A';
                document.getElementById('version').textContent = d.version || 'N/A';
            }).catch(()=>{});
            fetch(API+'/oci/billing').then(r=>r.json()).then(d=>{
                document.getElementById('oci-billing-value').textContent = d.total_sgd ? d.total_sgd+' SGD' : 'N/A';
            }).catch(()=>{});
        }
        
        // Auto-refresh
        refreshSystemInfo();
        setInterval(refreshSystemInfo, 30000);
        refreshCronJobs();
        setInterval(refreshCronJobs, 30000);

        function switchTab(tab) {
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            document.getElementById('page-' + tab).classList.add('active');
            event.currentTarget.classList.add('active');
        }

        function barColor(p) {
            if (p > 85) return 'fill-red';
            if (p > 60) return 'fill-yellow';
            return 'fill-green';
        }

        function formatUptime(seconds) {
            const d = Math.floor(seconds / 86400);
            const h = Math.floor((seconds % 86400) / 3600);
            if (d > 0) return d + 'd ' + h + 'h';
            const m = Math.floor((seconds % 3600) / 60);
            if (h > 0) return h + 'h ' + m + 'm';
            return m + 'm';
        }

        function formatBytes(bytes) {
            if (bytes === 0) return '0 B';
            const k = 1024;
            const sizes = ['B', 'KB', 'MB', 'GB', 'TB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(1)) + ' ' + sizes[i];
        }

        function formatSpeed(bytesPerSec) {
            return formatBytes(bytesPerSec) + '/s';
        }

        function esc(s) { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

        // === Monitor ===
        // === SSE 实时推送 ===
        let _sse = null;
        let _networkTimer = null;
        let _hermesTimer = null;
        let _pageVisible = true;
        const _animating = {};

        // 数值平滑过渡
        function animateValue(el, newVal, duration = 600) {
            const id = el.id;
            if (_animating[id]) return;
            const text = el.textContent;
            const oldVal = parseFloat(text);
            if (isNaN(oldVal) || Math.abs(oldVal - newVal) < 0.05) {
                el.textContent = newVal.toFixed(1) + '%';
                return;
            }
            _animating[id] = true;
            const start = performance.now();
            const suffix = text.includes('MB') ? ' MB' : text.includes('%') ? '%' : '';
            function step(now) {
                const progress = Math.min((now - start) / duration, 1);
                const eased = 1 - Math.pow(1 - progress, 3);
                const current = oldVal + (newVal - oldVal) * eased;
                el.textContent = current.toFixed(1) + suffix;
                if (progress < 1) {
                    requestAnimationFrame(step);
                } else {
                    el.textContent = newVal.toFixed(1) + suffix;
                    delete _animating[id];
                }
            }
            requestAnimationFrame(step);
        }

        // 页面可见性检测
        document.addEventListener('visibilitychange', () => {
            _pageVisible = !document.hidden;
            if (_pageVisible) {
                startSSE();
                startTimers();
            } else {
                stopSSE();
                stopTimers();
            }
        });

        function startSSE() {
            if (_sse) return;
            _sse = new EventSource(API + '/stream');
            _sse.onmessage = (e) => {
                try {
                    const d = JSON.parse(e.data);
                    if (d.error) return;
                    updateDashboard(d);
                } catch(err) { console.error('SSE parse error:', err); }
            };
            _sse.onerror = () => {
                console.log('SSE disconnected, reconnecting...');
                stopSSE();
                setTimeout(startSSE, 3000); // 3秒后重连
            };
        }
        function stopSSE() {
            if (_sse) { _sse.close(); _sse = null; }
        }

        function startTimers() {
            stopTimers();
            _networkTimer = setInterval(refreshMonthlyTraffic, 60000);
            _hermesTimer = setInterval(loadHermesData, 60000);
        }
        function stopTimers() {
            clearInterval(_networkTimer);
            clearInterval(_hermesTimer);
        }

        function updateDashboard(d) {
            const s = d.system;
            // CPU - 带动画
            animateValue(document.getElementById('cpu-val'), s.cpu.percent);
            const cpuBar = document.getElementById('cpu-bar');
            cpuBar.style.width = s.cpu.percent + '%';
            cpuBar.className = 'gauge-fill ' + barColor(s.cpu.percent);
            const cores = s.cpu.per_core || [];
            document.getElementById('cpu-detail').textContent = cores.map((v, i) => `C${i+1}:${v.toFixed(0)}%`).join(' ');
            
            // Memory - 带动画
            animateValue(document.getElementById('mem-val'), s.memory.percent);
            const memBar = document.getElementById('mem-bar');
            memBar.style.width = s.memory.percent + '%';
            memBar.className = 'gauge-fill ' + (s.memory.percent > 80 ? 'fill-red' : 'fill-blue');
            document.getElementById('mem-detail').textContent = formatBytes(s.memory.used) + ' / ' + formatBytes(s.memory.total);
            
            // Disk - 带动画
            animateValue(document.getElementById('disk-val'), s.disk.percent);
            const diskBar = document.getElementById('disk-bar');
            diskBar.style.width = s.disk.percent + '%';
            diskBar.className = 'gauge-fill ' + barColor(s.disk.percent);
            document.getElementById('disk-detail').textContent = formatBytes(s.disk.used) + ' / ' + formatBytes(s.disk.total);
            
            // Load
            document.getElementById('load-val').textContent = s.cpu.load1.toFixed(2);
            document.getElementById('load-detail').textContent = `1m: ${s.cpu.load1.toFixed(2)}  5m: ${s.cpu.load5.toFixed(2)}`;
            
            // Uptime
            const uptime = s.uptime && s.uptime > 0 ? formatUptime(s.uptime) : '--';
            document.getElementById('stat-uptime-monitor').textContent = uptime;
            document.getElementById('stat-uptime-hermes').textContent = uptime;
            document.getElementById('stat-uptime-ops').textContent = uptime;
            
            // Net speed
            var ns = s.io && s.io.net_speed ? s.io.net_speed : (s.net_speed || null);
            if (ns) {
                document.getElementById('net-up').textContent = formatSpeed(ns.upload_per_sec || ns.upload || 0);
                document.getElementById('net-down').textContent = formatSpeed(ns.download_per_sec || ns.download || 0);
            } else {
                // fallback: try top-level net fields
                if (s.net) {
                    document.getElementById('net-up').textContent = formatSpeed(s.net.upload || 0);
                    document.getElementById('net-down').textContent = formatSpeed(s.net.download || 0);
                }
            }
            
            // Processes
            const proc = d.processes;
            document.getElementById('cpu-top').innerHTML = '<div class="section-title">CPU TOP</div>' + (proc.cpu_top || []).slice(0,3).map(p => `
                <div class="proc-item">
                    <span class="proc-name">${esc(p.name)}</span>
                    <span class="proc-cpu">${p.cpu}%</span>
                </div>
            `).join('') || '<div class="section-title">CPU TOP</div><div style="color:var(--hint);font-size:11px">无数据</div>';
            
            document.getElementById('mem-top').innerHTML = '<div class="section-title">内存 TOP</div>' + (proc.mem_top || []).slice(0,3).map(p => {
                const mb = p.memory / 1048576;
                const memStr = mb >= 1024 ? (mb/1024).toFixed(1)+'G' : mb.toFixed(0)+'M';
                return `<div class="proc-item">
                    <span class="proc-name">${esc(p.name)}</span>
                    <span class="proc-mem">${memStr}</span>
                </div>`;
            }).join('') || '<div class="section-title">内存 TOP</div><div style="color:var(--hint);font-size:11px">无数据</div>';
            
            // Services
            const svcNames = { gateway: 'Gateway', hermes: 'Hermes', 'llama.embed': 'llama.embed' };
            document.getElementById('services-card').innerHTML = '<div class="section-title">服务状态</div>' + (d.services || []).map(svc => `
                <div class="info-row">
                    <span>${svcNames[svc.name] || svc.name}</span>
                    <span style="color:${svc.status === 'running' ? 'var(--success)' : 'var(--danger)'}">● ${svc.status === 'running' ? '运行中' : '未运行'}</span>
                </div>
            `).join('');
        }

        async function refreshMonthlyTraffic() {
            try {
                const r = await fetch(API + '/network');
                const d = await r.json();
                const MONTHLY_QUOTA = 10 * 1024 * 1024 * 1024 * 1024; // 10TB
                
                if (d.monthly) {
                    const total = d.monthly.rx + d.monthly.tx;
                    const used = formatBytes(total).replace(' ', '');
                    const percent = ((total / MONTHLY_QUOTA) * 100).toFixed(1);
                    document.getElementById('net-quota').textContent = `${used}/10T (${percent}%)`;
                } else if (d.boot_total) {
                    const total = d.boot_total.rx + d.boot_total.tx;
                    const used = formatBytes(total).replace(' ', '');
                    const percent = ((total / MONTHLY_QUOTA) * 100).toFixed(1);
                    document.getElementById('net-quota').textContent = `${used}/10T (${percent}%)`;
                }
            } catch(e) {}
        }

        async function loadHermesData() {
            try {
                const r = await fetch(API + '/hermes/summary');
                const d = await r.json();
                
                // Model
                const modelInfo = d.model || { model: '--', provider: '--' };
                document.getElementById('model-name').textContent = modelInfo.model || '--';
                document.getElementById('model-provider').textContent = 'Provider: ' + (modelInfo.provider || '--');
                
                // Platforms
                const icons = {
                    Telegram: '<svg viewBox="0 0 24 24" width="22" height="22" fill="#26A5E4"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>',
                    QQ: '<svg viewBox="0 0 24 24" width="22" height="22" fill="#12B7F5"><path d="M21.395 15.035a40 40 0 0 0-.803-2.264l-1.079-2.695c.001-.032.014-.562.014-.836C19.526 4.632 17.351 0 12 0S4.474 4.632 4.474 9.241c0 .274.013.804.014.836l-1.08 2.695a39 39 0 0 0-.802 2.264c-1.021 3.283-.69 4.643-.438 4.673.54.065 2.103-2.472 2.103-2.472 0 1.469.756 3.387 2.394 4.771-.612.188-1.363.479-1.845.835-.434.32-.379.646-.301.778.343.578 5.883.369 7.482.189 1.6.18 7.14.389 7.483-.189.078-.132.132-.458-.301-.778-.483-.356-1.233-.646-1.846-.836 1.637-1.384 2.393-3.302 2.393-4.771 0 0 1.563 2.537 2.103 2.472.251-.03.581-1.39-.438-4.673"/></svg>',
                    '微信': '<svg viewBox="0 0 24 24" width="22" height="22" fill="#07C160"><path d="M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 0 1 .213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.29.295a.326.326 0 0 0 .167-.054l1.903-1.114a.864.864 0 0 1 .717-.098 10.16 10.16 0 0 0 2.837.403c.276 0 .543-.027.811-.05-.857-2.578.157-4.972 1.932-6.446 1.703-1.415 3.882-1.98 5.853-1.838-.576-3.583-4.196-6.348-8.596-6.348zM5.785 5.991c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 0 1-1.162 1.178A1.17 1.17 0 0 1 4.623 7.17c0-.651.52-1.18 1.162-1.18zm5.813 0c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 0 1-1.162 1.178 1.17 1.17 0 0 1-1.162-1.178c0-.651.52-1.18 1.162-1.18zm5.34 2.867c-1.797-.052-3.746.512-5.28 1.786-1.72 1.428-2.687 3.72-1.78 6.22.942 2.453 3.666 4.229 6.884 4.229.826 0 1.622-.12 2.361-.336a.722.722 0 0 1 .598.082l1.584.926a.272.272 0 0 0 .14.047c.134 0 .24-.111.24-.247 0-.06-.023-.12-.038-.177l-.327-1.233a.582.582 0 0 1-.023-.156.49.49 0 0 1 .201-.398C23.024 18.48 24 16.82 24 14.98c0-3.21-2.931-5.837-6.656-6.088V8.89c-.135-.01-.27-.027-.407-.03zm-2.53 3.274c.535 0 .969.44.969.982a.976.976 0 0 1-.969.983.976.976 0 0 1-.969-.983c0-.542.434-.982.97-.982zm4.844 0c.535 0 .969.44.969.982a.976.976 0 0 1-.969.983.976.976 0 0 1-.969-.983c0-.542.434-.982.969-.982z"/></svg>'
                };
                document.getElementById('platform-grid').innerHTML = Object.entries(d.platforms || {}).map(([name, online]) => `
                    <div class="platform-item">
                        <div class="platform-icon">${icons[name] || '📡'}</div>
                        <div class="platform-name">${name}</div>
                        <div class="platform-status ${online ? 'online' : 'offline'}">${online ? '在线' : '离线'}</div>
                    </div>
                `).join('');
                
                // Memory
                const memInfo = d.memory || {};
                document.getElementById('stat-memory').textContent = memInfo.total || '--';
                document.getElementById('stat-mem-queries').textContent = memInfo.today_queries || 0;
                document.getElementById('stat-mem-writes').textContent = memInfo.today_writes || 0;
                
                const hasWrites = (memInfo.today_writes || 0) > 0;
                const hasQueries = (memInfo.today_queries || 0) > 0;
                const hasActivity = hasWrites || hasQueries;
                
                document.getElementById('write-bridge')?.classList.toggle('idle', !hasWrites);
                document.getElementById('query-bridge')?.classList.toggle('idle', !hasQueries);
                document.getElementById('stat-brain')?.classList.toggle('idle', !hasActivity);
                
                // Embedding
                const embedInfo = d.embedding || { engine: '--', models: [], vector_db: '--', active: false };
                const embedModel = embedInfo.models.length > 0 
                    ? embedInfo.models.map(m => m.name).join(', ')
                    : (embedInfo.active ? '无' : '离线');

                const engines = [
                    { name: 'LLM', value: modelInfo.model, icon: '🤖' },
                    { name: '记忆', value: memInfo.provider || '--', icon: '💾' },
                    { name: '向量引擎', value: embedInfo.engine + ' · ' + embedModel, icon: '🧮' },
                    { name: '向量库', value: embedInfo.vector_db, icon: '🔎' },
                ];
                document.getElementById('engine-list').innerHTML = engines.map(e => `
                    <div class="info-row">
                        <span>${e.icon} ${e.name}</span>
                        <span style="color:var(--accent);font-size:12px">${e.value}</span>
                    </div>
                `).join('');
            } catch(e) {}
        }

        // === Maintenance ===
        let opsHistory = [];

        function logOps(msg, type = 'info') {
            const time = new Date().toLocaleTimeString('zh-CN');
            opsHistory.unshift(`[${time}] ${msg}`);
            if (opsHistory.length > 10) opsHistory.pop();
            const colors = { info: 'var(--text)', success: 'var(--success)', error: 'var(--danger)' };
            document.getElementById('ops-log').innerHTML = opsHistory.map(m => 
                `<div style="color:${colors[type] || 'var(--text)'};font-size:12px;padding:4px 0">${m}</div>`
            ).join('');
        }

        async function emergencyRestart() {
            if (!confirm('⚠️ 确定要执行紧急重启吗？\n\n这将杀掉所有 Hermes 相关进程并重启 Gateway。')) return;
            logOps('🚨 执行紧急重启...', 'info');
            try {
                const body = opsPassword ? { ops_password: opsPassword } : {};
                const r = await fetch(API + '/ops/emergency-restart', {
                    method: 'POST',
                    headers: { 'X-API-Token': TOKEN, 'Content-Type': 'application/json' },
                    body: JSON.stringify(body)
                });
                const d = await r.json();
                if (d.results) {
                    d.results.forEach(res => logOps(res, res.includes('✅') ? 'success' : 'info'));
                    logOps('✅ 紧急重启完成', 'success');
                } else {
                    logOps('❌ ' + (d.error || '未知错误'), 'error');
                }
            } catch(e) {
                logOps('❌ 请求失败: ' + e.message, 'error');
            }
        }

        async function restartService(service) {
            logOps(`🔄 重启 ${service}...`, 'info');
            try {
                const body = { service };
                if (opsPassword) body.ops_password = opsPassword;
                const r = await fetch(API + '/ops/restart-service', {
                    method: 'POST',
                    headers: { 'X-API-Token': TOKEN, 'Content-Type': 'application/json' },
                    body: JSON.stringify(body)
                });
                const d = await r.json();
                if (d.exit_code === 0) {
                    logOps(`✅ ${service} 重启成功`, 'success');
                } else {
                    logOps(`❌ ${service} 重启失败`, 'error');
                }
            } catch(e) {
                logOps('❌ 请求失败: ' + e.message, 'error');
            }
        }

        // === Chat ===
        let chatHistory = [];
        let chatStreaming = false;

        document.getElementById('chat-input').addEventListener('keydown', e => {
            if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendChat(); }
        });

        async function sendChat() {
            const input = document.getElementById('chat-input');
            const msg = input.value.trim();
            if (!msg || chatStreaming) return;
            chatStreaming = true;
            input.value = '';
            const btn = document.getElementById('chat-send');
            btn.disabled = true;
            btn.textContent = '...';

            const box = document.getElementById('chat-messages');
            // 用户消息
            box.innerHTML += `<div class="chat-msg user">${esc(msg)}</div>`;
            box.scrollTop = box.scrollHeight;

            chatHistory.push({role: 'user', content: msg});

            // 助手占位
            const assistantDiv = document.createElement('div');
            assistantDiv.className = 'chat-msg assistant';
            assistantDiv.innerHTML = '<span class="chat-typing">●●●</span>';
            box.appendChild(assistantDiv);
            box.scrollTop = box.scrollHeight;

            try {
                const r = await fetch(API + '/chat/qwen35', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json', 'X-API-Token': TOKEN},
                    body: JSON.stringify({messages: chatHistory})
                });
                const reader = r.body.getReader();
                const decoder = new TextDecoder();
                let fullText = '';
                let buffer = '';

                while (true) {
                    const {done, value} = await reader.read();
                    if (done) break;
                    buffer += decoder.decode(value, {stream: true});
                    const lines = buffer.split('\n');
                    buffer = lines.pop();
                    for (const line of lines) {
                        if (!line.startsWith('data: ')) continue;
                        const json = line.slice(6);
                        if (json === '[DONE]') break;
                        try {
                            const d = JSON.parse(json);
                            // 网页抓取状态
                            if (d.status === 'fetched') {
                                assistantDiv.innerHTML = `<span style="color:var(--hint)">📄 已抓取 ${d.length} 字符...</span>`;
                            } else if (d.reasoning) {
                                // reasoning 实时显示到聊天气泡（蓝色斜体）
                                assistantDiv.innerHTML += `<span style="color:#60a5fa;font-style:italic;font-size:13px">${esc(d.reasoning)}</span>`;
                                box.scrollTop = box.scrollHeight;
                            } else if (d.content) {
                                fullText += d.content;
                                assistantDiv.textContent = fullText;
                                box.scrollTop = box.scrollHeight;
                            }
                        } catch(e) {}
                    }
                }
                chatHistory.push({role: 'assistant', content: fullText});
                if (!fullText) assistantDiv.textContent = '（无响应）';
                // Markdown 渲染
                else {
                    assistantDiv.style.opacity = '0';
                    assistantDiv.innerHTML = marked.parse(fullText);
                    setTimeout(() => assistantDiv.style.transition = 'opacity 0.3s', 10);
                    setTimeout(() => assistantDiv.style.opacity = '1', 20);
                }
            } catch(e) {
                assistantDiv.textContent = '❌ ' + e.message;
            }
            chatStreaming = false;
            btn.disabled = false;
            btn.textContent = '发送';
        }

        // === 页面巡查功能已移除 ===

        // === Init ===
        startSSE();
        refreshMonthlyTraffic();
        loadHermesData();
        checkOpsAccess();
        startTimers();

        // 当前时间显示（每秒更新）
        function updateCurrentTime() {
            document.getElementById('current-time').textContent = new Date().toLocaleTimeString('zh-CN');
        }
        updateCurrentTime();
        setInterval(updateCurrentTime, 1000);

        // === 维护页面访问控制 ===
        let opsAuthenticated = false;
        let opsPassword = '';

        async function checkOpsAccess() {
            try {
                const r = await fetch(API + '/ops/check-access');
                if (!r.ok) {
                    console.error('check-access returned', r.status);
                    document.getElementById('ops-login').style.display = 'block';
                    document.getElementById('ops-login').style.display = 'none'; // hide card
                    document.getElementById('ops-ip-msg').textContent = '服务器错误: ' + r.status;
                    return;
                }
                const d = await r.json();
                console.log('checkOpsAccess:', d);
                if (d.allowed) {
                    // IP 白名单，直接显示操作面板
                    opsAuthenticated = true;
                    // 先隐藏验证卡片，再显示操作面板
                    const loginEl = document.getElementById('ops-login');
                    const panelEl = document.getElementById('ops-panel');
                    loginEl.style.display = 'none';
                    panelEl.style.display = 'block';

                } else {
                    // 需要密码验证
                    document.getElementById('ops-login').style.display = 'block';
                    document.getElementById('ops-panel').style.display = 'none';
                    document.getElementById('ops-ip-msg').textContent = `您的 IP (${d.ip}) 无权访问，请输入密码`;
                }
            } catch(e) {
                console.error('checkOpsAccess error:', e);
                document.getElementById('ops-login').style.display = 'block';
                document.getElementById('ops-panel').style.display = 'none';
                document.getElementById('ops-ip-msg').textContent = '无法验证访问权限，请输入密码';
            }
        }

        async function submitOpsPassword() {
            const input = document.getElementById('ops-password-input');
            const pwd = input.value.trim();
            if (!pwd) return;
            try {
                const r = await fetch(API + '/ops/verify-password', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({password: pwd})
                });
                const d = await r.json();
                if (d.success) {
                    opsAuthenticated = true;
                    opsPassword = pwd;
                    document.getElementById('ops-panel').style.display = 'block';
                    document.getElementById('ops-login').style.display = 'none';

                } else {
                    input.value = '';
                    input.style.borderColor = '#ef4444';
                    setTimeout(() => input.style.borderColor = '', 1500);
                }
            } catch(e) {}
        }

        // === OCI Billing ===
        async function refreshOciBilling() {
            try {
                const r = await fetch(API + '/oci/billing');
                const d = await r.json();
                if (d.status === 'ok') {
                    const updated = new Date(d.updated_at).toLocaleString('zh-CN');
                    document.getElementById('oci-billing-card').innerHTML = '\n                        <div class="section-title">☁️ OCI 账单</div>\n                        <div class="traffic-row">\n                            <span class="traffic-label">当月费用</span>\n                            <span class="traffic-value" style="color:var(--accent)">' + d.total_sgd + ' ' + d.currency + '</span>\n                        </div>\n                        <div class="traffic-row">\n                            <span class="traffic-label">账单月份</span>\n                            <span class="traffic-value">' + d.month + '</span>\n                        </div>\n                        <div class="traffic-row">\n                            <span class="traffic-label">更新于</span>\n                            <span class="traffic-value" style="font-size:11px;color:var(--hint)">' + updated + '</span>\n                        </div>\n                    ';
                } else {
                    document.getElementById('oci-billing-card').innerHTML = '\n                        <div class="section-title">☁️ OCI 账单</div>\n                        <div class="traffic-row"><span class="traffic-label">状态</span><span class="traffic-value" style="color:var(--danger)">' + (d.error || '加载失败') + '</span></div>\n                    ';
                }
            } catch(e) {
                document.getElementById('oci-billing-card').innerHTML = '\n                    <div class="section-title">☁️ OCI 账单</div>\n                    <div class="traffic-row"><span class="traffic-label">状态</span><span class="traffic-value" style="color:var(--danger)">网络错误</span></div>\n                ';
            }
        }

        // === Cron Jobs ===
        async function refreshCronJobs() {
            try {
                const r = await fetch(API + '/cron/list');
                const d = await r.json();
                const jobs = d.jobs || [];
                if (jobs.length === 0) {
                    document.getElementById('cron-card').innerHTML = '\n                        <div class="section-title">⏰ 定时任务</div>\n                        <div class="traffic-row"><span class="traffic-label">状态</span><span class="traffic-value" style="color:var(--hint)">暂无定时任务</span></div>\n                    ';
                } else {
                    const rows = jobs.map(function(j) {
                        var name = j.name || j.job_id || '未知';
                        var lastRun = j.last_run || '';
                        var isOk = lastRun.trim().endsWith('ok');
                        var statusColor = isOk ? 'var(--accent)' : 'var(--danger)';
                        var statusText = isOk ? '✅ 成功' : '❌ 失败';
                        var next = j.next_run || '--';
                        return '<div class="cron-job-row">\n                            <span class="cron-name">' + esc(name) + '</span>\n                            <span class="cron-status" style="color:' + statusColor + '">' + statusText + '</span>\n                            <span class="cron-next">下次: ' + esc(next) + '</span>\n                        </div>';
                    }).join('');
                    document.getElementById('cron-card').innerHTML = '\n                        <div class="section-title">⏰ 定时任务 (' + jobs.length + ')</div>\n                        ' + rows + '\n                    ';
                }
            } catch(e) {
                document.getElementById('cron-card').innerHTML = '\n                    <div class="section-title">⏰ 定时任务</div>\n                    <div class="traffic-row"><span class="traffic-label">状态</span><span class="traffic-value" style="color:var(--danger)">网络错误</span></div>\n                ';
            }
        }

        // Auto-refresh
        refreshOciBilling();
        refreshCronJobs();
        setInterval(refreshOciBilling, 600000);
        setInterval(refreshCronJobs, 30000);
    </script>
</body>
</html>
